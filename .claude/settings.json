{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\tools\\hooks\\post-edit-build.ps1\""
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\tools\\hooks\\stop-selftest.ps1\""
					}
				]
			}
		]
	}
}
